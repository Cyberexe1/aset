{
  "manifest_version": 3,
  "name": "ASET — Verify Scientific Claims",
  "version": "1.0.0",
  "description": "Highlight any text and verify scientific claims against 1.2M+ peer-reviewed papers instantly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.aset-ai.tech/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ASET Claim Verifier"
  }
}
