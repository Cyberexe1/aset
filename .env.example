# Database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token

# Server
PORT=3001
NODE_ENV=production

# AI
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_key
GROQ_API_KEY_2=your_groq_key_2
GROQ_API_KEY_3=your_groq_key_3
GROQ_API_KEY_4=your_groq_key_4

# APIs
NASA_ADS_API_KEY=your_nasa_ads_key
YOUTUBE_API_KEY=your_youtube_key
SUPADATA_API_KEY=your_supadata_key

# Email (Nodemailer)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# ─── Sponsor Integrations ──────────────────────────────────────────────────

# Redis (Beyond Caching) — agent memory, verification history, research cache
# Get a free Redis Cloud instance at: https://redis.com/try-free/
REDIS_URL=redis://localhost:6379

# Fetch.ai Agentverse — multi-agent pipeline registration
# Register agents at: https://agentverse.ai
AGENTVERSE_URL=https://agentverse.ai
FETCHAI_RESEARCH_AGENT_ADDRESS=agent1q...
FETCHAI_VERIFICATION_AGENT_ADDRESS=agent1q...
FETCHAI_CITATION_AGENT_ADDRESS=agent1q...
FETCHAI_REPORT_AGENT_ADDRESS=agent1q...
FETCHAI_RESEARCH_MAILBOX_KEY=your_mailbox_key
FETCHAI_VERIFICATION_MAILBOX_KEY=your_mailbox_key
FETCHAI_CITATION_MAILBOX_KEY=your_mailbox_key
FETCHAI_REPORT_MAILBOX_KEY=your_mailbox_key

# Band Protocol — inter-agent message relay
# Get testnet tokens at: https://laozi-testnet6.bandchain.org
BAND_CHAIN_ID=band-laozi-testnet6
BAND_ENDPOINT=https://laozi-testnet6.bandchain.org/grpc-web
BAND_MNEMONIC=your_24_word_mnemonic
BAND_ORACLE_SCRIPT_ID=0

# Browserbase — managed browser sessions for web evidence extraction
# Sign up at: https://browserbase.com
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_project_id

# Arize — LLM observability and hallucination tracking
# Sign up at: https://arize.com or run Phoenix OSS: https://phoenix.arize.com
ARIZE_API_KEY=your_arize_api_key
ARIZE_SPACE_ID=your_space_id
ARIZE_MODEL_ID=aset-verification
ARIZE_MODEL_VERSION=2.0.0
ARIZE_PHOENIX_URL=http://localhost:6006
# Or use OTLP endpoint directly:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.arize.com/v1
